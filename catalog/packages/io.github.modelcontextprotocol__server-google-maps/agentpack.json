{
  "name": "io.github.modelcontextprotocol/server-google-maps",
  "version": "2024.11.5",
  "description": "MCP server for Google Maps API — geocoding, directions, places, and elevation",
  "type": "mcp-server",
  "transport": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-google-maps"]
  },
  "provides": {
    "capabilities": ["maps", "geocoding", "directions", "places"]
  },
  "dependencies": {},
  "tools": [
    {"name": "maps_geocode", "description": "Convert an address to coordinates"},
    {"name": "maps_reverse_geocode", "description": "Convert coordinates to an address"},
    {"name": "maps_directions", "description": "Get directions between two locations"},
    {"name": "maps_search_places", "description": "Search for places near a location"},
    {"name": "maps_elevation", "description": "Get elevation data for coordinates"}
  ]
}
