{
  "name": "io.github.agentpack-demo/weather",
  "version": "1.0.0",
  "description": "MCP server for weather data",
  "type": "mcp-server",
  "provides": {
    "capabilities": ["weather-data", "forecast"],
    "protocol": "mcp"
  },
  "transport": {"type": "stdio", "command": "node", "args": ["servers/weather/index.js"]},
  "dependencies": {"io.github.agentpack-demo/geocoding": "^1.0.0"},
  "tools": [
    {"name": "get_weather", "description": "Get current weather"},
    {"name": "get_forecast", "description": "Get 3-day forecast"}
  ]
}
