{
  "name": "io.github.agentpack-demo/geocoding",
  "version": "1.0.0",
  "description": "MCP server for geocoding",
  "type": "mcp-server",
  "provides": {
    "capabilities": ["geocoding", "reverse-geocoding"],
    "protocol": "mcp"
  },
  "transport": {"type": "stdio", "command": "node", "args": ["servers/geocoding/index.js"]},
  "dependencies": {},
  "tools": [
    {"name": "geocode", "description": "Address to coordinates"},
    {"name": "reverse_geocode", "description": "Coordinates to address"}
  ]
}
